# Terraform providers and plugins (run `terraform init` to restore)
terraform/.terraform/

# Terraform state — contains secrets and resource IDs
terraform/*.tfstate
terraform/*.tfstate.*
terraform/terraform.tfvars
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# Deployment-specific state and configs
deployments/

# Lambda build artifacts (regenerated by `terraform apply`)
terraform/lambda/*.zip

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Kiro
.kiro/

# DevSecOps - Generated files (safe to ignore)
ferret-sast-report.json
ferret-scan-results.sarif
.ash/
.eslintcache

# DevSecOps - Tool cache directories
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Auto-generated security scanning files
.devsecops/
.pre-commit-config.yaml
licensecheck.toml

# DSR
.dsr/
